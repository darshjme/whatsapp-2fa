# Server
PORT=3000
API_KEY=your-secret-api-key-here

# OTP Settings
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3

# WhatsApp message template (use {{otp}} as placeholder)
OTP_MESSAGE_TEMPLATE=Your verification code is: *{{otp}}*\n\nThis code expires in 5 minutes. Do not share it with anyone.
