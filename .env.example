# Server
PORT=3000
API_KEY=your-secret-api-key-here
APP_NAME=MyApp

# OTP Settings
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_SECONDS=60

# Rate Limiting (per phone number)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=3600

# WhatsApp message template (use {{otp}} and {{app_name}} as placeholders)
OTP_MESSAGE_TEMPLATE=Your {{app_name}} verification code is: *{{otp}}*\n\nThis code expires in 5 minutes. Do not share it with anyone.

# Logging
LOG_LEVEL=info
